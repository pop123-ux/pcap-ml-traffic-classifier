# ============================================================
# PCAP-ML-Traffic-Classifier — .gitignore
# ============================================================

# ------------------------------------------------------------
# Network Capture Files (heavy binary artifacts — never commit)
# ------------------------------------------------------------
*.pcap
*.pcapng
*.cap

# ------------------------------------------------------------
# CatBoost Training Artifacts
# ------------------------------------------------------------
# Temporary training telemetry (learning curves, TensorBoard logs)
catboost_info/

# Serialized model binaries
*.cbm
*.pkl
traffic_model.pkl
catboost_traffic_model.cbm

# ------------------------------------------------------------
# Python Cache & Bytecode
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# ------------------------------------------------------------
# Virtual Environments
# ------------------------------------------------------------
venv/
.venv/
env/
.env/
ENV/

# ------------------------------------------------------------
# Packaging / Distribution
# ------------------------------------------------------------
build/
dist/
*.egg-info/
.eggs/

# ------------------------------------------------------------
# Testing & Coverage
# ------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/

# ------------------------------------------------------------
# IDE / Editor Noise
# ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo

# ------------------------------------------------------------
# OS Junk
# ------------------------------------------------------------
.DS_Store
Thumbs.db
